[sqruff]
dialect = postgres
rules = core, layout.newlines
max_line_length = 200

[sqruff:indentation]
indent_unit = space
tab_space_size = 4

[sqruff:layout:type:data_type]
spacing_before = align
align_within = create_table_statement

[sqruff:layout:type:column_constraint_segment]
spacing_before = align
align_within = create_table_statement

[sqruff:layout:type:expression]
spacing_within = single:inline

[sqruff:rules:layout.newlines]
maximum_empty_lines_inside_statements = 0
